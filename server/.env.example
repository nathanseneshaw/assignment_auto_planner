# Canvas LMS OAuth (Instructure Cloud or self-hosted)
# Create a Developer Key in Canvas: Admin → Developer Keys → + Developer Key
# Set Redirect URI to match CANVAS_REDIRECT_URI exactly (e.g. http://localhost:3001/api/canvas/oauth/callback)

CANVAS_CLIENT_ID=
CANVAS_CLIENT_SECRET=

# Must match the redirect URL registered on the Canvas developer key
CANVAS_REDIRECT_URI=http://localhost:3001/api/canvas/oauth/callback

# Where the server sends the user after OAuth (your Vite app)
FRONTEND_URL=http://localhost:5173

# Optional: default port for the API server
# PORT=3001
