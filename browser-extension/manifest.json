{
  "manifest_version": 3,
  "name": "Assignment Auto-Planner - Blackboard Sync",
  "version": "1.1.0",
  "description": "Automatically sync courses and assignments from Blackboard to Assignment Auto-Planner",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "contextMenus",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.blackboard.com/*",
        "*://*learn*/*",
        "*://*elearning*/*",
        "*://*lms*/*",
        "*://*/*/ultra/*",
        "*://*/*/webapps/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
