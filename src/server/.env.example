# Where the SPA runs (used for CORS). Your Vercel app origin, no trailing slash.
FRONTEND_URL=http://localhost:5173

# CORS: optional extra browser origins (comma-separated). Production + previews if needed.
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-preview.vercel.app

# Render sets PORT automatically. Optional bind address (default 0.0.0.0)
# PORT=3001
# HOST=0.0.0.0

# Supabase — required for ICS routes.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=eyJ...

# Service-role key — optional but strongly recommended for hosted deployments.
# When set, ICS write operations (course/assignment upserts, feed status updates)
# bypass RLS and use explicit user_id filters for defence-in-depth. Never set this
# in an Electron/desktop build — it would be embedded in the binary.
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
