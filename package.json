{
  "name": "assignment-auto-planner",
  "private": true,
  "version": "1.0.0",
  "description": "Automatically plan and manage your assignments from Blackboard",
  "type": "module",
  "main": "electron/main.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "cd src/server && npm start",
    "server:dev": "cd src/server && npm run dev",
    "server:test": "cd src/server && npm test",
    "server:install": "npm install",
    "render:build": "npm install",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env ELECTRON_DEV=true electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:preview": "cross-env ELECTRON_DEV=false electron ."
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@supabase/supabase-js": "^2.105.3",
    "@vueuse/core": "^14.2.1",
    "archiver": "^7.0.1",
    "cheerio": "^1.0.0",
    "claude": "^0.1.2",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "fetch-cookie": "^3.0.1",
    "node-fetch": "^3.3.2",
    "node-ical": "^0.20.1",
    "pinia": "^3.0.4",
    "tough-cookie": "^4.1.3",
    "vue": "^3.5.12",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@vitejs/plugin-vue": "^5.1.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "vercel": "^53.2.0",
    "vite": "^5.4.10",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.assignmentplanner.app",
    "productName": "Assignment Planner",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
