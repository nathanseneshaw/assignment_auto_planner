{
  "name": "assignment-auto-planner",
  "private": true,
  "version": "1.0.0",
  "description": "Automatically plan and manage your assignments from Blackboard",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "cd src/server && npm start",
    "server:dev": "cd src/server && npm run dev",
    "server:test": "cd src/server && npm test",
    "server:install": "npm install && npx playwright install chromium",
    "playwright:install": "cd src/server && npx playwright install chromium",
    "render:build": "npm install && npx playwright install chromium"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.3",
    "@vueuse/core": "^14.2.1",
    "archiver": "^7.0.1",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "fetch-cookie": "^3.0.1",
    "node-fetch": "^3.3.2",
    "pinia": "^3.0.4",
    "playwright": "^1.59.1",
    "tough-cookie": "^4.1.3",
    "vue": "^3.5.12",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "vercel": "^53.2.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "vite": "^5.4.10"
  }
}
