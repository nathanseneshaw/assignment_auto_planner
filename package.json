{
  "name": "assignment-auto-planner",
  "private": true,
  "version": "1.0.0",
  "description": "Plan your coursework by subscribing to your school's iCalendar (ICS) feeds.",
  "type": "module",
  "main": "electron/main.js",
  "author": {
    "name": "Nathan",
    "email": "nathanseneshaw438@gmail.com"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node src/server/index.js",
    "server:dev": "node --watch src/server/index.js",
    "server:test": "node --test ./src/server/tests/*.test.mjs",
    "render:build": "npm install",
    "electron:dev": "concurrently \"cross-env VITE_BUILD_TARGET=electron vite\" \"npm:server:dev\" \"wait-on http://localhost:5173 tcp:127.0.0.1:3001 && cross-env ELECTRON_DEV=true electron .\"",
    "preelectron:build": "node electron/scripts/generate-server-env.js && node electron/scripts/copy-server-deps.js",
    "electron:build": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false VITE_BUILD_TARGET=electron vite build && electron-builder",
    "electron:preview": "cross-env ELECTRON_DEV=false electron ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@supabase/supabase-js": "^2.105.3",
    "@vueuse/core": "^14.2.1",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.1",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "node-ical": "^0.20.1",
    "pdf-parse": "^1.1.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.12",
    "vue-router": "^4.6.4",
    "ws": "^8.20.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@vitejs/plugin-vue": "^5.1.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "vercel": "^53.2.0",
    "vite": "^5.4.10",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.assignmentplanner.app",
    "productName": "Assignment Planner",
    "copyright": "Copyright © 2026 Nathan",
    "forceCodeSigning": false,
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "icon": "electron/icon.png",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "src/server",
        "to": "server",
        "filter": [
          "**/*",
          "!.env*",
          "!.vercel/**",
          "!.gitignore",
          "!package-lock.json",
          "!tests/**",
          "!*.test.*",
          "!node_modules/assignment-auto-planner/**/*",
          "!node_modules/.package-lock.json"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
